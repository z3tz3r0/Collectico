{
  "name": "collectico-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --project tsconfig.app.json && tsc --project tsconfig.node.json",
    "check": "npm run lint && npm run typecheck && npm run build",
    "lint": "eslint src/app src/shared src/contexts/AuthContext.tsx src/contexts/CartContext.tsx src/pages/ProtectedRoute.tsx service/api.ts src/main.tsx src/App.ts src/router.ts eslint.config.js vite.config.js --max-warnings=0",
    "lint:fix": "npm run lint -- --fix",
    "lint-staged": "lint-staged",
    "prepare": "cd .. && husky collectico-frontend/.husky",
    "preview": "vite preview"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --fix --max-warnings=0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fontsource/roboto": "^5.2.5",
    "@libsql/client": "^0.15.4",
    "@mui/icons-material": "^7.0.2",
    "@mui/lab": "^7.0.0-beta.10",
    "@mui/material": "^7.0.2",
    "@mui/styled-engine-sc": "^7.0.1",
    "@mui/x-data-grid": "^7.28.3",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.94.5",
    "axios": "^1.9.0",
    "bcrypt": "^5.1.1",
    "body-parser": "^2.2.0",
    "chart.js": "^4.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "mongoose": "^8.13.2",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.2.4",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.13.1",
    "socket.io-client": "^4.8.1",
    "styled-components": "^6.1.17",
    "swiper": "^11.2.8",
    "tailwind-scrollbar-hide": "^2.0.0",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vite": "^8.0.1"
  }
}
